# Copie este arquivo para .env e preencha com a sua chave da Anthropic.
# O .env é ignorado pelo git (ver .gitignore) e nunca deve ser versionado.
ANTHROPIC_API_KEY=coloque-sua-chave-aqui

# (Opcional) Caminho alternativo para o SQLite, caso a pasta padrão
# não suporte bem o SQLite:
# SRAG_DB_PATH=/caminho/para/srag.db
